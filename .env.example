# ── 只读库（训练数据来源，严禁写入）──────────────────────────
# bank_account_statement / account_chart 两张表
DB_HOST=172.16.14.100
DB_PORT=3306
DB_NAME=hcsw_audit
DB_USER=root
DB_PASSWORD=uEvE6Z4VvUQMRAus

# ── 模型路径 ───────────────────────────────────────────────────
# BASE_MODEL_PATH: 基础预训练模型目录（bge-base-zh-v1.5 或 bge-small-zh-v1.5）
# FINETUNED_MODEL_DIR: 微调模型存储目录，versions.json 也写在此目录下
BASE_MODEL_PATH=models/base
FINETUNED_MODEL_DIR=models/finetuned

# ── 训练参数 ───────────────────────────────────────────────────
# BATCH_LIMIT: 每次训练最多从数据库读取多少条流水
BATCH_LIMIT=50000
# MIN_TRAIN_SAMPLES: 最少需要多少条流水才触发训练（--force 可忽略此限制）
MIN_TRAIN_SAMPLES=200
# MAX_SAMPLES_PER_SUBJECT: 每个科目去重后最多保留多少条（0 = 不限制）
MAX_SAMPLES_PER_SUBJECT=500

# ── 日志 ───────────────────────────────────────────────────────
LOG_DIR=logs
LOG_DEBUG=false

# ── SCP 部署（上传训练好的模型到云端服务器）──────────────────
DEPLOY_HOST=your-server-ip
DEPLOY_USER=ubuntu
# 云端服务器上微调模型的存放目录（需与 Web 服务的模型路径一致）
DEPLOY_REMOTE_DIR=/data/hcsw-audit/models/finetuned
# SSH 私钥路径，留空则上传时交互输入密码
DEPLOY_KEY_PATH=
# 上传后重启的 systemd 服务名（执行 deploy.py --reload 时使用）
DEPLOY_SERVICE_NAME=subject-matcher
